# =========================================================
# Configuración de conexión a RDS PostgreSQL
# =========================================================
DB_HOST=your-instance.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# =========================================================
# Configuración de rclone
# =========================================================
# Nombre del remote de rclone configurado para Google Drive
RCLONE_REMOTE=gdrive
# Carpeta destino dentro de Google Drive
RCLONE_DEST_PATH=database-backups
# Ruta al archivo de configuración de rclone.
# Necesario cuando el script lo ejecuta root (cron/sudo) pero rclone
# fue configurado con otro usuario. Obtén la ruta con: rclone config file
RCLONE_CONFIG=/home/pabloblanco/.config/rclone/rclone.conf

# =========================================================
# Configuración de retención local
# =========================================================
# Directorio donde se guardan los dumps temporalmente
LOCAL_BACKUP_DIR=/var/backups/db-dumps
# Días que se conservan los archivos locales antes de borrarlos
LOCAL_RETENTION_DAYS=3

# =========================================================
# Tablas exportadas sin datos (opcional)
# =========================================================
# Lista de tablas cuya estructura se exporta pero sin filas.
# Útil para tablas de auditoría o logs muy voluminosos.
# Separar con comas. Acepta patrones glob (ej: audit_*, session_*).
EXCLUDE_TABLE_DATA=audit_log

# =========================================================
# Notificaciones (opcional)
# =========================================================
# Email para notificaciones de error (requiere mailutils instalado)
# Dejar vacío para deshabilitar
NOTIFY_EMAIL=
